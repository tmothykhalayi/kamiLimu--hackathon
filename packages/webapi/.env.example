# Azure AI Foundry / Inference (recommended for this project)
AZURE_INFERENCE_SDK_ENDPOINT=https://<resource>.services.ai.azure.com/models
AZURE_INFERENCE_SDK_KEY=<your-key>
DEPLOYMENT_NAME=gpt-4.1_AIFoundry

# Alternative env var name (also supported)
# AZURE_INFERENCE_ENDPOINT=https://<resource>.services.ai.azure.com/models

# Google Gemini (optional)
# GEMINI_API_KEY=<your-key>
# GEMINI_MODEL=gemini-2.0-flash

PORT=3001
